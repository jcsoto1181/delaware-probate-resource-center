---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | Delaware Probate Resource Center">

<section class="contact-hero">
  <div class="container">
    <p class="eyebrow">Free Probate Property Help</p>
    <h1>Request Help With an Inherited Property</h1>
    <p>
      Have questions about a probate property, inherited home, or next steps in Delaware?
      Use this page to request the free guide or ask about a free consultation.
    </p>
  </div>
</section>

<section class="contact-content">
  <div class="container contact-grid">

    <div class="contact-card">
      <h2>Request the Free Guide</h2>
      <p>
        Get the Delaware Probate Property Guide, created for Delaware families,
        executors, heirs, and estate representatives.
      </p>
      <a class="button" href="mailto:gh824517@gmail.com?subject=Request%20Delaware%20Probate%20Property%20Guide">
        Request the Guide
      </a>
    </div>

    <div class="contact-card dark">
      <h2>Schedule a Free Probate Property Consultation</h2>
      <p>
        If you are dealing with an inherited property and need help understanding
        your options, you can request a no-pressure conversation.
      </p>
      <a class="button light" href="mailto:gh824517@gmail.com?subject=Free%20Probate%20Property%20Consultation">
        Request Consultation
      </a>
    </div>

  </div>
</section>

<section class="info-section">
  <div class="container">
    <h2>What to Include in Your Message</h2>
    <ul>
      <li>Your name</li>
      <li>The Delaware county where the property is located</li>
      <li>Whether you are an executor, administrator, heir, or family member</li>
      <li>Whether probate has already been opened</li>
      <li>Your biggest question or concern</li>
    </ul>

    <p class="note">
      Delaware Probate Resource Center provides educational information and property-related guidance.
      For legal advice, consult a qualified Delaware attorney.
    </p>
  </div>
</section>

<style>
  .container {
    width: min(1100px, 92%);
    margin: 0 auto;
  }

  .contact-hero {
    background: #eef3f7;
    padding: 85px 0;
  }

  .eyebrow {
    color: #0f766e;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
  }

  h1 {
    color: #12355b;
    font-size: 3.8rem;
    line-height: 1.05;
    margin: 10px 0 20px;
  }

  h2 {
    color: #12355b;
  }

  p,
  li {
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .contact-content {
    padding: 80px 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 26px;
  }

  .contact-card {
    background: white;
    border: 1px solid #dbe3ea;
    border-radius: 16px;
    padding: 34px;
    box-shadow: 0 15px 35px rgba(15, 23, 42, 0.06);
  }

  .contact-card.dark {
    background: #12355b;
    color: white;
  }

  .contact-card.dark h2 {
    color: white;
  }

  .button {
    display: inline-block;
    margin-top: 20px;
    background: #0f766e;
    color: white;
    padding: 14px 24px;
    border-radius: 8px;
    font-weight: 800;
    text-decoration: none;
  }

  .button.light {
    background: white;
    color: #12355b;
  }

  .info-section {
    padding: 30px 0 80px;
  }

  .note {
    margin-top: 35px;
    background: #eef3f7;
    padding: 22px;
    border-radius: 12px;
  }

  @media (max-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: 2.7rem;
    }
  }
</style>

</BaseLayout>