---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="New Castle County Probate Property Guide">

<section class="hero">
  <div class="container">
    <p class="eyebrow">New Castle County Probate Help</p>

    <h1>
      Probate Property Guidance for New Castle County Families
    </h1>

    <p>
      Educational resources for executors, heirs, administrators,
      and families handling inherited real estate in Wilmington,
      Newark, Bear, Middletown, Claymont, and throughout New Castle County.
    </p>
  </div>
</section>

<section class="content">
  <div class="container">

    <h2>Common Questions We Hear</h2>

    <ul>
      <li>Do I need probate before selling a house?</li>
      <li>Can multiple heirs sell inherited property?</li>
      <li>What happens if the property has liens?</li>
      <li>How long does probate take in Delaware?</li>
      <li>What if the home needs repairs?</li>
    </ul>

    <h2>Communities We Serve</h2>

    <p>
      Wilmington, Newark, Bear, Middletown, Claymont,
      New Castle, Elsmere, Pike Creek, Hockessin,
      and surrounding communities.
    </p>

  </div>
</section>

<style>
.hero {
  background:#eef3f7;
  padding:80px 0;
}

.container {
  width:min(1100px,92%);
  margin:auto;
}

.eyebrow {
  color:#0f766e;
  text-transform:uppercase;
  font-weight:800;
}

h1 {
  color:#12355b;
  font-size:4rem;
}

.content {
  padding:80px 0;
}

h2 {
  color:#12355b;
}

p, li {
  font-size:1.1rem;
  line-height:1.8;
}
</style>

</BaseLayout>