---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | Delaware Probate Resource Center">

<section class="about-hero">
  <div class="container">
    <h1>About Delaware Probate Resource Center</h1>

    <p>
      Delaware Probate Resource Center was created to help Delaware families,
      executors, heirs, and estate representatives make informed decisions
      when dealing with inherited property and probate-related real estate.
    </p>
  </div>
</section>

<section class="about-content">
  <div class="container">

    <h2>Our Mission</h2>

    <p>
      Our mission is to provide free educational resources, guidance,
      and Delaware-specific information so families can confidently
      navigate probate and inherited property decisions.
    </p>

    <h2>Who We Help</h2>

    <ul>
      <li>Executors</li>
      <li>Administrators</li>
      <li>Heirs</li>
      <li>Families inheriting property</li>
      <li>Estate representatives</li>
    </ul>

    <h2>Educational First</h2>

    <p>
      We believe families deserve clear information before making
      important property decisions. Our goal is to serve as a trusted
      Delaware probate resource and connect people with solutions when needed.
    </p>

  </div>
</section>

<style>
  .container {
    width: min(1100px, 92%);
    margin: 0 auto;
  }

  .about-hero {
    padding: 80px 0;
    background: #eef3f7;
  }

  .about-hero h1 {
    color: #12355b;
    font-size: 3rem;
    margin-bottom: 20px;
  }

  .about-hero p {
    max-width: 800px;
    font-size: 1.2rem;
    line-height: 1.7;
  }

  .about-content {
    padding: 80px 0;
  }

  .about-content h2 {
    color: #12355b;
    margin-top: 40px;
  }

  .about-content p,
  .about-content li {
    font-size: 1.1rem;
    line-height: 1.8;
  }
</style>

</BaseLayout>