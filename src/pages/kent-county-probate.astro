---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Kent County Probate Property Guide">

<section class="hero">
  <div class="container">
    <p class="eyebrow">Kent County Probate Help</p>

    <h1>
      Probate Property Guidance for Kent County Families
    </h1>

    <p>
      Educational resources for executors, heirs, administrators,
      and families handling inherited real estate in Dover,
      Smyrna, Camden, Harrington, Felton, Milford,
      and throughout Kent County.
    </p>
  </div>
</section>

<section class="content">
  <div class="container">

    <h2>Common Probate Questions</h2>

    <ul>
      <li>Can inherited property be sold during probate?</li>
      <li>How are multiple heirs handled?</li>
      <li>What happens if the home has liens?</li>
      <li>How long does probate take?</li>
      <li>Can an executor sell the property?</li>
    </ul>

    <h2>Communities We Serve</h2>

    <p>
      Dover, Smyrna, Camden, Harrington,
      Felton, Milford, Magnolia,
      and surrounding Kent County communities.
    </p>

  </div>
</section>

<style>
.hero {
  background:#eef3f7;
  padding:80px 0;
}

.container {
  width:min(1100px,92%);
  margin:auto;
}

.eyebrow {
  color:#0f766e;
  text-transform:uppercase;
  font-weight:800;
}

h1 {
  color:#12355b;
  font-size:4rem;
}

.content {
  padding:80px 0;
}

h2 {
  color:#12355b;
}

p, li {
  font-size:1.1rem;
  line-height:1.8;
}
</style>

</BaseLayout>