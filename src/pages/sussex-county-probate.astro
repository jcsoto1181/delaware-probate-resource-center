---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Sussex County Probate Property Guide">

<section class="hero">
  <div class="container">
    <p class="eyebrow">Sussex County Probate Help</p>

    <h1>
      Probate Property Guidance for Sussex County Families
    </h1>

    <p>
      Educational resources for executors, heirs, administrators,
      and families handling inherited real estate in Georgetown,
      Seaford, Lewes, Rehoboth Beach, Milton,
      Millsboro, Laurel, and throughout Sussex County.
    </p>
  </div>
</section>

<section class="content">
  <div class="container">

    <h2>Common Probate Questions</h2>

    <ul>
      <li>What if the inherited house needs repairs?</li>
      <li>Can multiple heirs agree to sell?</li>
      <li>How are debts handled during probate?</li>
      <li>How long does probate usually take?</li>
      <li>What happens if there is no will?</li>
    </ul>

    <h2>Communities We Serve</h2>

    <p>
      Georgetown, Seaford, Lewes,
      Rehoboth Beach, Milton,
      Millsboro, Laurel,
      and surrounding Sussex County communities.
    </p>

  </div>
</section>

<style>
.hero {
  background:#eef3f7;
  padding:80px 0;
}

.container {
  width:min(1100px,92%);
  margin:auto;
}

.eyebrow {
  color:#0f766e;
  text-transform:uppercase;
  font-weight:800;
}

h1 {
  color:#12355b;
  font-size:4rem;
}

.content {
  padding:80px 0;
}

h2 {
  color:#12355b;
}

p, li {
  font-size:1.1rem;
  line-height:1.8;
}
</style>

</BaseLayout>